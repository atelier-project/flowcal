# Which backend the frontend talks to: "supabase" (default) or "api" (self-hosted Express + Postgres)
VITE_BACKEND=supabase

# Required when VITE_BACKEND=supabase
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key-here

# Required when VITE_BACKEND=api, in dev only (the API runs on its own origin).
# Leave empty for the single-container production build, where the API serves the SPA.
VITE_API_URL=http://localhost:3001

# UI-only for the supabase backend: set false to hide the sign-up form. Real
# enforcement is Supabase's project Auth setting. (For the api backend, use the
# server-side SIGNUPS_ENABLED instead.) Default: true.
VITE_SIGNUPS_ENABLED=true
