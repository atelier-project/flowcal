# Postgres connection string
DATABASE_URL=postgres://flowcal:flowcal@localhost:5432/flowcal

# Secret used to sign session JWTs. MUST be set to a long random value in production.
JWT_SECRET=change-me-to-a-long-random-string
JWT_EXPIRES_IN=7d

# Optional: on startup, promote this (already signed-up) account to admin.
# Lets you designate an admin without container exec — set it and restart.
# ADMIN_EMAIL=you@example.com

# Set to false to close new registrations: /signup returns 403 and the login
# page hides the sign-up form. Existing users can still sign in. Default: true.
SIGNUPS_ENABLED=true

# Server
PORT=3001
NODE_ENV=development

# Dev only: origin of the Vite dev server, for credentialed CORS.
CLIENT_ORIGIN=http://localhost:5173

# Set true when serving over HTTPS so the session cookie is marked Secure.
COOKIE_SECURE=false

# Prod: absolute path to the built SPA (dist/) for the API to serve. Leave empty
# in dev (Vite serves the SPA).
STATIC_DIR=
